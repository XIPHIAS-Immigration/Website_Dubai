# Site
NEXT_PUBLIC_SITE_URL=https://www.xiphiasimmigration.com
SITE_URL=https://www.xiphiasimmigration.com

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_TO=
ELIGIBILITY_EMAIL_TO=
PARTNER_EMAIL_TO=
B2G_EMAIL_TO=

# Eligibility assessment report funnel
# Free flow sends a branded preview/trailer. Paid detailed-report registration uses a separate Topmate product.
NEXT_PUBLIC_ASSESSMENT_REPORT_PRICE_INR=10000
NEXT_PUBLIC_ASSESSMENT_REPORT_PAYMENT_URL=/registration
ASSESSMENT_REPORT_PRICE_INR=10000
ASSESSMENT_REPORT_PAYMENT_URL=/registration
# Create a INR 10,000 Topmate product manually, then paste that payment URL here.
TOPMATE_REGISTRATION_URL=
NEXT_PUBLIC_TOPMATE_REGISTRATION_URL=
# Topmate/Zapier/Make/admin automation posts paid customers to /api/platform/registration/provision.
XIPHIAS_REGISTRATION_WEBHOOK_SECRET=

# Jiopay hosted checkout
# Keep JIOPAY_SECRET_KEY out of Git. Set UAT URLs from the Jiopay API collection/developer portal.
JIOPAY_MODE=uat
JIOPAY_MERCHANT_ID=JP2001100068129
JIOPAY_SECRET_KEY=
JIOPAY_INITIATE_SALE_URL=https://uat.jiopay.co.in/tsp/pg/api/v2/initiateSale
JIOPAY_STATUS_URL=https://uat.jiopay.co.in/tsp/pg/api/command
JIOPAY_RETURN_URL=https://www.xiphiasimmigration.com/api/payments/jiopay/return
JIOPAY_WEBHOOK_URL=https://www.xiphiasimmigration.com/api/payments/jiopay/webhook
JIOPAY_STORE_PATH=
JIOPAY_DEFAULT_AMOUNT_INR=5000
# Keep false for UAT/manual review. Set true only when paid orders should automatically provision X-Hub.
JIOPAY_AUTO_PROVISION=false
NEXT_PUBLIC_JIOPAY_CHECKOUT_ENABLED=false

# Chat / XIA Lite
# Default uses deterministic XIA Lite. Set NEXT_PUBLIC_XIA_LITE_MODE=n8n to use NEXT_PUBLIC_N8N_CHAT_URL.
NEXT_PUBLIC_XIA_LITE_MODE=internal
NEXT_PUBLIC_N8N_CHAT_URL=
# Optional server-side tiny conversation model for warmer answer phrasing.
# Keep this server-side; do not ship model code to the browser.
# Values: rules, ollama, openai-compatible
XIA_CONVERSATION_MODEL_PROVIDER=rules
# Ollama example: http://127.0.0.1:11434/api/chat
# OpenAI-compatible example: https://your-provider.example/v1/chat/completions
XIA_CONVERSATION_MODEL_ENDPOINT=
XIA_CONVERSATION_MODEL=
XIA_CONVERSATION_MODEL_API_KEY=

# WhatsApp Cloud API
META_WABA_TOKEN=
META_WABA_PHONE_NUMBER_ID=
WHATSAPP_TO=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# Portal auth
# Production should set XIPHIAS_PORTAL_USERS to JSON with passwordSha256 values.
# Example:
# XIPHIAS_PORTAL_USERS=[{"email":"admin@example.com","name":"Admin","role":"admin","passwordSha256":"<sha256>"}]
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://www.xiphiasimmigration.com
AUTH_URL=https://www.xiphiasimmigration.com
# Local dev with npm run dev should use:
# NEXTAUTH_URL=http://localhost:4000
# AUTH_URL=http://localhost:4000
XIPHIAS_PORTAL_USERS=

# Future Postgres repository
DATABASE_URL=

# Legacy CRM integration
# Keep credentials in .env.local or secret storage only. XIPHIAS_CRM_DATABASE_URL
# should point to the restored SQL Server CRM database after india-crm.sql is imported.
XIPHIAS_CRM_DATABASE_URL=
XIPHIAS_CRM_BACKUP_ROOT=E:\XIPHIAS_data_backup
XIPHIAS_CRM_SQL_ROOT=G:\XIPHIAS-IMMIGRATION-Server-Backup-2023\Database
XIPHIAS_CRM_FILE_STORAGE_ROOT=G:\XIPHIAS-IMMIGRATION-Server-Backup-2023\wwwroot\xiphiasimmigration.com\XIPHIAS\XIPHIAS_IMMIGRATION\IMMIGRATION_CRM_TRAIL_PRIVATE
XIPHIAS_CRM_FILE_STORAGE_ROOTS=G:\XIPHIAS-IMMIGRATION-Server-Backup-2023\wwwroot\xiphiasimmigration.com\XIPHIAS\XIPHIAS_IMMIGRATION\IMMIGRATION_CRM_TRAIL_PRIVATE;G:\2026-06-01\XIPHIAS_IMMIGRATION\IMMIGRATION_CRM_TRAIL_PRIVATE;G:\Accounts Data\Immigration data\INDIAN CRM\XCRM\XIPHIAS\IMMIGRATION_CRM_TRAIL_PRIVATE
XIPHIAS_CRM_SQL_HOST=localhost
XIPHIAS_CRM_SQL_PORT=14333
XIPHIAS_CRM_SQL_USER=sa
XIPHIAS_CRM_SQL_PASSWORD=
XIPHIAS_CRM_SQL_ENCRYPT=true
XIPHIAS_CRM_SQL_TRUST_SERVER_CERTIFICATE=true
XIPHIAS_CRM_INDIA_DATABASE=immigration_com
XIPHIAS_CRM_DUBAI_DATABASE=dubai_crm

# Platform storage / uploads
# Local/demo defaults write to .xiphias-platform. Use managed storage in production.
XIPHIAS_PLATFORM_STORAGE=file
XIPHIAS_PLATFORM_STORE_PATH=
XIPHIAS_UPLOAD_DIR=

# Compliance vendor integration
# If empty, XIPHIAS Hub Risk Review runs explicit demo screening only.
COMPLIANCE_VENDOR_NAME=
COMPLIANCE_VENDOR_ENDPOINT=
COMPLIANCE_VENDOR_API_KEY=
